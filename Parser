"""
    Parses a route finding problem file and returns a structured dictionary.
    Returns:
        {
            'Location ':
            'Scats Number':
            'Date': int,
            'Latitude': int,
            'Longitude': int,
            'Time': int,
            '"Vehicle_Count": int
        }
    """
#creates a parser class to read the excel file and return the data in a structured format 
#Passes in the filename as a object paramter and reads the data using pandas

class Parser(object):
    def __init__(self, filename):
        self.filename = filename
        self.data = pd.read_excel(filename)
    def return_data(self): 
        return self.data #returns the whole data 
    def return_location(self):
        # Get the second column
        location_column = self.data.iloc[:, 1] 
        return location_column 
    def return_scats_number(self): 
        # Get the first column
        scats_number_column = self.data.iloc[:, 0]
        return scats_number_column 
    def return_date(self):
        # Get the date column 
        date_column = self.data.iloc[:, 9] 
        return date_column  
    def return_nb_latitdue(self):
        # Get the latitude column 
        latitude_column = self.data.iloc[:, 3]
        return latitude_column 
    def return_nb_longitude(self):
        # Get the longitude column 
        longitude_column = self.data.iloc[:, 4]
        return longitude_column        
    def get_time_slots(self):
        # Get the time slots from the header of the time columns 
        time_slots= []
        time_slots = self.data.columns[10:106]  
        return time_slots 
    def get_vehicle_count(self): 
        # Get the vehicle count for each node and time slot 
        vehicle_count = self.data.iloc[:, 10:106] 
        return vehicle_count 
 
